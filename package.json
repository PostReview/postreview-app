{
  "name": "postreview-app",
  "version": "1.0.0",
  "engines": {
    "node": "16.14.0"
  },
  "scripts": {
    "start:production": "blitz start --port $PORT",
    "dev": "blitz dev",
    "build": "blitz build",
    "start": "blitz start",
    "studio": "blitz prisma studio",
    "lint": "eslint --ignore-path .gitignore --ext .js,.ts,.tsx .",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky install"
  },
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@algolia/autocomplete-js": "1.6.2",
    "@algolia/autocomplete-theme-classic": "1.6.2",
    "@emotion/react": "11.9.0",
    "@emotion/styled": "11.8.1",
    "@mui/icons-material": "5.6.2",
    "@mui/lab": "5.0.0-alpha.78",
    "@mui/material": "5.6.2",
    "@prisma/client": "3.12.0",
    "algoliasearch": "4.13.0",
    "autoprefixer": "10.4.4",
    "axios": "0.26.1",
    "blitz": "0.45.4",
    "final-form": "4.20.6",
    "passport-google-oauth20": "2.0.0",
    "postcss": "8.4.12",
    "prisma": "3.12.0",
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "react-final-form": "6.5.9",
    "react-icons": "4.3.1",
    "react-likert-scale": "4.1.2",
    "survey-react": "1.9.25",
    "ts-node": "10.7.0",
    "tslib": "2.3.1",
    "typescript": "4.6.3",
    "zod": "3.14.4"
  },
  "devDependencies": {
    "@iconify/react": "3.2.1",
    "@types/node": "17.0.25",
    "@types/preview-email": "2.0.1",
    "@types/react": "18.0.5",
    "eslint": "8.13.0",
    "husky": "7.0.4",
    "lint-staged": "12.3.8",
    "prettier": "2.6.2",
    "prettier-plugin-prisma": "3.12.0",
    "pretty-quick": "3.1.3",
    "preview-email": "3.0.5",
    "tailwindcss": "3.0.24"
  },
  "private": true,
  "cacheDirectories": [
    ".next/cache"
  ]
}
